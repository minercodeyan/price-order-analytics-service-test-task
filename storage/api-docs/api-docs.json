{
    "openapi": "3.0.0",
    "info": {
        "title": "Order API",
        "description": "Price Order Analytics Service API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8080",
            "description": "Local server"
        },
        {
            "url": "https://api.yourdomain.com",
            "description": "Production server"
        }
    ],
    "paths": {
        "/api/orders/{id}": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "Get order by ID",
                "description": "Retrieve detailed information about a specific order by its ID",
                "operationId": "903fca5af3c36fdf07eb35920f0508e5",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Order ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "hash": {
                                                    "type": "string",
                                                    "example": "abc123def456"
                                                },
                                                "number": {
                                                    "type": "string",
                                                    "example": "ORD-00001"
                                                },
                                                "status": {
                                                    "type": "integer",
                                                    "example": 5
                                                },
                                                "status_text": {
                                                    "type": "string",
                                                    "example": "Доставлен"
                                                },
                                                "client_name": {
                                                    "type": "string",
                                                    "example": "Иван"
                                                },
                                                "client_surname": {
                                                    "type": "string",
                                                    "example": "Петров"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "ivan@example.com"
                                                },
                                                "company_name": {
                                                    "type": "string",
                                                    "nullable": true
                                                },
                                                "total_amount": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 1250.5
                                                },
                                                "currency": {
                                                    "type": "string",
                                                    "example": "EUR"
                                                },
                                                "discount": {
                                                    "type": "integer",
                                                    "nullable": true
                                                },
                                                "create_date": {
                                                    "type": "string",
                                                    "format": "date-time"
                                                },
                                                "delivery": {
                                                    "properties": {
                                                        "cost": {
                                                            "type": "number",
                                                            "format": "float",
                                                            "example": 150
                                                        },
                                                        "city": {
                                                            "type": "string",
                                                            "example": "Москва"
                                                        },
                                                        "address": {
                                                            "type": "string",
                                                            "example": "ул. Тверская, д. 1"
                                                        },
                                                        "tracking_number": {
                                                            "type": "string",
                                                            "example": "TRK123456"
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "payment": {
                                                    "properties": {
                                                        "type": {
                                                            "type": "integer",
                                                            "example": 1
                                                        },
                                                        "full_payment_date": {
                                                            "type": "string",
                                                            "format": "date",
                                                            "nullable": true
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "items": {
                                                    "type": "array",
                                                    "items": {
                                                        "properties": {
                                                            "id": {
                                                                "type": "integer",
                                                                "example": 1
                                                            },
                                                            "article_sku": {
                                                                "type": "string",
                                                                "example": "PLATE-001"
                                                            },
                                                            "amount": {
                                                                "type": "number",
                                                                "format": "float",
                                                                "example": 10
                                                            },
                                                            "price": {
                                                                "type": "number",
                                                                "format": "float",
                                                                "example": 50.5
                                                            }
                                                        },
                                                        "type": "object"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Заказ не найден",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Заказ не найден"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/search/orders": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "Search orders (*)",
                "description": "Search orders using Manticore (*)",
                "operationId": "a229660fe2b7420527992ba29b647aa7",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search query (order number, email, client name, etc.)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "ORD-00001"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Search results returned successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "number": {
                                                        "type": "string",
                                                        "example": "ORD-00001"
                                                    },
                                                    "email": {
                                                        "type": "string",
                                                        "example": "ivan@example.com"
                                                    },
                                                    "client_name": {
                                                        "type": "string",
                                                        "example": "Иван"
                                                    },
                                                    "client_surname": {
                                                        "type": "string",
                                                        "example": "Петров"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid query",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Query required"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/orders/statistics": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "Get orders statistics with grouping and pagination",
                "operationId": "68fefc74cfee57fb6f887ab203eb7274",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Page number",
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Items per page",
                        "schema": {
                            "type": "integer",
                            "default": 15,
                            "maximum": 100,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "group_by",
                        "in": "query",
                        "description": "Grouping period",
                        "schema": {
                            "type": "string",
                            "default": "month",
                            "enum": [
                                "day",
                                "month",
                                "year"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "period": {
                                                        "type": "string",
                                                        "example": "2025-01"
                                                    },
                                                    "orders_count": {
                                                        "type": "integer",
                                                        "example": 15
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        },
                                        "current_page": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "per_page": {
                                            "type": "integer",
                                            "example": 15
                                        },
                                        "total": {
                                            "type": "integer",
                                            "example": 50
                                        },
                                        "last_page": {
                                            "type": "integer",
                                            "example": 4
                                        },
                                        "group_by": {
                                            "type": "string",
                                            "example": "month"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/price": {
            "get": {
                "tags": [
                    "Prices"
                ],
                "summary": "Get product price from tile.expert",
                "description": "Parse product page and return price in EUR",
                "operationId": "a1e6635cf0eb082b59558a0c5dfed4f3",
                "parameters": [
                    {
                        "name": "factory",
                        "in": "query",
                        "description": "Factory name",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "marca-corona"
                        }
                    },
                    {
                        "name": "collection",
                        "in": "query",
                        "description": "Collection name",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "arteseta"
                        }
                    },
                    {
                        "name": "article",
                        "in": "query",
                        "description": "Article code",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "k263-arteseta-camoscio-s000628660"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Price retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "price": {
                                            "type": "number",
                                            "format": "float",
                                            "example": 59.99
                                        },
                                        "factory": {
                                            "type": "string",
                                            "example": "marca-corona"
                                        },
                                        "collection": {
                                            "type": "string",
                                            "example": "arteseta"
                                        },
                                        "article": {
                                            "type": "string",
                                            "example": "k263-arteseta-camoscio-s000628660"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Price not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Не найдена цена по данному артикулу."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/soap/order": {
            "post": {
                "tags": [
                    "Orders"
                ],
                "summary": "Create order via SOAP",
                "description": "Create a new order via SOAP protocol (REST wrapper). Requires API key in header.",
                "operationId": "625c2764b5a6defff41b1fc151d3c58e",
                "requestBody": {
                    "description": "Order data",
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "total_amount",
                                    "items",
                                    "payment"
                                ],
                                "properties": {
                                    "email": {
                                        "description": "Customer email",
                                        "type": "string",
                                        "format": "email",
                                        "example": "customer@example.com"
                                    },
                                    "user_id": {
                                        "description": "User ID (optional)",
                                        "type": "integer",
                                        "example": 1,
                                        "nullable": true
                                    },
                                    "client_name": {
                                        "description": "First name",
                                        "type": "string",
                                        "example": "John",
                                        "nullable": true
                                    },
                                    "client_surname": {
                                        "description": "Last name",
                                        "type": "string",
                                        "example": "Doe",
                                        "nullable": true
                                    },
                                    "company_name": {
                                        "description": "Company name",
                                        "type": "string",
                                        "example": "ACME Corp",
                                        "nullable": true
                                    },
                                    "currency": {
                                        "description": "Currency code",
                                        "type": "string",
                                        "example": "EUR",
                                        "default": "EUR",
                                        "maxLength": 3
                                    },
                                    "total_amount": {
                                        "description": "Total order amount",
                                        "type": "number",
                                        "format": "float",
                                        "example": 1500
                                    },
                                    "discount": {
                                        "description": "Discount percentage (0-100)",
                                        "type": "integer",
                                        "example": 10,
                                        "nullable": true,
                                        "maximum": 100,
                                        "minimum": 0
                                    },
                                    "locale": {
                                        "description": "Locale",
                                        "type": "string",
                                        "example": "en_US",
                                        "maxLength": 5
                                    },
                                    "name": {
                                        "description": "Order name",
                                        "type": "string",
                                        "example": "My Order",
                                        "nullable": true
                                    },
                                    "items": {
                                        "description": "Order items",
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "article_id",
                                                "amount",
                                                "price"
                                            ],
                                            "properties": {
                                                "article_id": {
                                                    "description": "Article ID",
                                                    "type": "integer",
                                                    "example": 1001
                                                },
                                                "amount": {
                                                    "description": "Quantity",
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 10.5,
                                                    "minimum": 0.001
                                                },
                                                "price": {
                                                    "description": "Unit price",
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 99.99,
                                                    "minimum": 0
                                                },
                                                "price_eur": {
                                                    "description": "Price in EUR",
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 99.99,
                                                    "nullable": true
                                                },
                                                "currency": {
                                                    "description": "Item currency",
                                                    "type": "string",
                                                    "example": "EUR",
                                                    "maxLength": 3
                                                },
                                                "measure": {
                                                    "description": "Unit of measure",
                                                    "type": "string",
                                                    "example": "m",
                                                    "maxLength": 2
                                                },
                                                "weight": {
                                                    "description": "Weight",
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 25.5,
                                                    "nullable": true
                                                },
                                                "packaging_count": {
                                                    "description": "Packaging count",
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 1,
                                                    "default": 1
                                                },
                                                "pallet": {
                                                    "description": "Pallet quantity",
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 0,
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "minItems": 1
                                    },
                                    "delivery": {
                                        "description": "Delivery information",
                                        "properties": {
                                            "cost": {
                                                "description": "Delivery cost",
                                                "type": "number",
                                                "format": "float",
                                                "example": 50
                                            },
                                            "cost_eur": {
                                                "description": "Delivery cost in EUR",
                                                "type": "number",
                                                "format": "float",
                                                "example": 50
                                            },
                                            "type": {
                                                "description": "0 - client address, 1 - warehouse address",
                                                "type": "integer",
                                                "example": 0,
                                                "enum": [
                                                    0,
                                                    1
                                                ]
                                            },
                                            "country_id": {
                                                "description": "Country ID",
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "city": {
                                                "description": "City",
                                                "type": "string",
                                                "example": "Berlin"
                                            },
                                            "address": {
                                                "description": "Address line",
                                                "type": "string",
                                                "example": "Main Str. 123"
                                            },
                                            "phone": {
                                                "description": "Phone number",
                                                "type": "string",
                                                "example": "+49123456789"
                                            }
                                        },
                                        "type": "object",
                                        "nullable": true
                                    },
                                    "payment": {
                                        "description": "Payment information",
                                        "required": [
                                            "type"
                                        ],
                                        "properties": {
                                            "type": {
                                                "description": "1-card, 2-bank transfer, 3-cash",
                                                "type": "integer",
                                                "example": 1,
                                                "enum": [
                                                    1,
                                                    2,
                                                    3
                                                ]
                                            },
                                            "vat_type": {
                                                "description": "0-private person, 1-VAT payer",
                                                "type": "integer",
                                                "example": 0,
                                                "enum": [
                                                    0,
                                                    1
                                                ]
                                            },
                                            "vat_number": {
                                                "description": "VAT number",
                                                "type": "string",
                                                "example": "DE123456789",
                                                "maxLength": 100
                                            },
                                            "tax_number": {
                                                "description": "Tax number",
                                                "type": "string",
                                                "example": "123/456/789",
                                                "maxLength": 50
                                            }
                                        },
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Order created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "order_id": {
                                                    "type": "integer",
                                                    "example": 12345
                                                },
                                                "order_number": {
                                                    "type": "string",
                                                    "example": "2412156789"
                                                },
                                                "hash": {
                                                    "type": "string",
                                                    "example": "a1b2c3d4e5f6789012345678"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Заказ успешно создан"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Ошибка валидации"
                                        },
                                        "errors": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - Invalid or missing API key",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Invalid API key"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Business logic error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Не найден артикул с ID 1001"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Database connection error"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            },
            "ApiKeyAuth": {
                "type": "apiKey",
                "description": "API Key for authentication. Test key: TEST_1J89U4948482NC",
                "name": "X-API-Key",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Orders",
            "description": "Orders"
        },
        {
            "name": "Prices",
            "description": "Prices"
        }
    ]
}